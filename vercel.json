{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/main.py"
        },
        {
            "source": "/technical/(.*)",
            "destination": "/frontend/technical_page/$1"
        },
        {
            "source": "/technical",
            "destination": "/frontend/technical_page/index.html"
        },
        {
            "source": "/service/(.*)",
            "destination": "/frontend/service_page/$1"
        },
        {
            "source": "/service",
            "destination": "/frontend/service_page/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/main_landing_page/$1"
        }
    ]
}